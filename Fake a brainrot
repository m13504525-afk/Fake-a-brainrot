-- MANTIK 1: Real or Fake (Swap & Detector)
local isSwapping = false
ActionBtn.MouseButton1Click:Connect(function()
    if currentMode == 1 then -- SWAP MODU
        if isSwapping then return end
        local char = Player.Character
        local bp = Player.Backpack
        if char and bp then
            local current = char:FindFirstChildOfClass("Tool")
            local nextT = bp:FindFirstChildOfClass("Tool")
            if nextT then
                isSwapping = true
                ActionBtn.Text = "Takaslanıyor..."
                local old = current
                if old then old.Parent = bp task.wait(0.1) end
                nextT.Parent = char
                task.wait(3)
                if nextT and nextT.Parent == char then nextT.Parent = bp end
                task.wait(0.1)
                if old then old.Parent = char end
                ActionBtn.Text = "Real or Fake (Swap)"
                isSwapping = false
            end
        end
    else -- DETECTOR MODU
        local found = false
        local char = Player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local myPos = char.HumanoidRootPart.Position
            for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local targetPos = v.Character.HumanoidRootPart.Position
                    -- 1 Stud mesafe kontrolü (XZ düzleminde) ve sonsuz Y
                    local distanceXZ = (Vector2.new(myPos.X, myPos.Z) - Vector2.new(targetPos.X, targetPos.Z)).Magnitude
                    if distanceXZ <= 1 then
                        found = true
                        break
                    end
                end
            end
        end
        
        if found then
            DetectorLabel.Text = "SAHTE"
            DetectorLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
        else
            DetectorLabel.Text = "GERÇEK"
            DetectorLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        end
        
        DetectorLabel.Visible = true
        task.wait(2)
        DetectorLabel.Visible = false
    end
end)

-- MANTIK 2: Invisible Brainrot
local invisibleActive = false
local storedTool = nil
InvisibleBtn.MouseButton1Click:Connect(function()
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local animate = char:FindFirstChild("Animate")
    invisibleActive = not invisibleActive
    if invisibleActive then
        InvisibleBtn.Text = "Invisible Brainrot: ON"
        InvisibleBtn.TextColor3 = Color3.fromRGB(255, 0, 255)
        local current = char:FindFirstChildOfClass("Tool")
        if current then storedTool = current current.Parent = Player.Backpack end
        if animate then animate.Disabled = true end
        for _, track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
    else
        InvisibleBtn.Text = "Invisible Brainrot: OFF"
        InvisibleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        if animate then animate.Disabled = false end
        if storedTool and storedTool.Parent == Player.Backpack then storedTool.Parent = char storedTool = nil end
    end
end)

-- MANTIK 3: ULTRA FAST ESP
local espActive = false
local espObjects = {}
local function removeEsp(plr)
    if espObjects[plr] then
        for _, obj in pairs(espObjects[plr]) do obj:Destroy() end
        espObjects[plr] = nil
    end
end

EspBtn.MouseButton1Click:Connect(function()
    espActive = not espActive
    if espActive then
        EspBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
        EspStroke.Color = Color3.fromRGB(0, 255, 0)
    else
        EspBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        EspStroke.Color = Color3.fromRGB(255, 0, 255)
        for plr, _ in pairs(espObjects) do removeEsp(plr) end
    end
end)

